# URL of your Railway backend (no trailing slash)
NEXT_PUBLIC_API_URL=https://fidge-email-production.up.railway.app/api

# Marketplace
NEXT_PUBLIC_ETH_WALLET=0xYourEthereumWalletAddressHere

# ── Ad Provider ──────────────────────────────────────────────────────────────
# Controls which ad networks are active:
#   "adsterra"  → Adsterra only (start here, no approval needed)
#   "adsense"   → Google AdSense only (after approval)
#   "both"      → AdSense display + Adsterra popunder/social bar simultaneously
#   leave empty → Dev placeholder (for local testing)
NEXT_PUBLIC_AD_PROVIDER=adsterra

# ── Google AdSense ────────────────────────────────────────────────────────────
# Get these from: AdSense dashboard → Ads → By ad unit → Display ad
# Required when AD_PROVIDER is "adsense" or "both"
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=1234567890

# ── Adsterra ─────────────────────────────────────────────────────────────────
# Get these from: Adsterra dashboard → create ad unit → copy script src URL
# Required when AD_PROVIDER is "adsterra" or "both"
#
# Social Bar — sticky notification-style ad, runs passively on all pages
# Adsterra → Publishers → Sites → Add site → Social Bar → copy the script src
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR=https://your-adsterra-social-bar-script.js
#
# Popunder — fires a background tab when Watch Ad modal opens
# Adsterra → Publishers → Sites → Add site → Onclick (Popunder) → copy script src
NEXT_PUBLIC_ADSTERRA_POPUNDER=https://your-adsterra-popunder-script.js
